#!/bin/sh
# Refreshes apt's package index (metadata only — a few hundred KB, not a
# package download) and records how many packages are upgradable, for
# venu-pacific-notify-updates to read. Runs as root (via
# venu-pacific-update-check.timer) since refreshing apt's lists needs
# write access to /var/lib/apt/lists. Never downloads or installs the
# packages themselves — bandwidth here is often capped/metered, so
# fetching is always the user's own choice, made in Synaptic.

set -e

STATE_DIR=/var/lib/venu-pacific
mkdir -p "$STATE_DIR"

apt-get update -qq

count=$(apt list --upgradable 2>/dev/null | grep -c '/' || true)
echo "$count" > "$STATE_DIR/update-count"
chmod 644 "$STATE_DIR/update-count"
