#!/usr/bin/env python3
"""Venu Pacific Hub -- single entry-point launcher.

Not a rewrite or a merge of the existing apps -- each tile below just
launches the app that already does that job (venu-pacific-assistant,
venu-pacific-kolibri, venu-pacific-services-directory,
venu-pacific-disaster-info). Deliberately thin: almost no logic here to
get wrong, since all the real functionality already works independently.
Kept as a separate optional entry point rather than replacing the
individual apps' own menu entries -- both stay visible, so nothing about
opening an app directly regresses.

Safety (disaster-info) and Services (services-directory) launch their own
fast, AI-independent apps directly rather than being folded into the
assistant's window -- that's deliberate: emergency safety info needs to
stay usable even if the AI/LLM component is slow to start, crashed, or
never launched at all. See ROADMAP.md's "one app vs several" discussion
for the full reasoning.

UI chrome strings are gettext-wrapped under the "venu-pacific-hub" domain
(kept separate from the other apps' domains so catalogs stay
independently sized, same convention used throughout this project).
"""

import gettext
import os
import subprocess

import gi

gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
from gi.repository import Gdk, GdkPixbuf, Gtk  # noqa: E402

LOGO_PATH = "/usr/share/pixmaps/venu-pacific.png"

gettext.bindtextdomain("venu-pacific-hub", "/usr/share/locale")
gettext.textdomain("venu-pacific-hub")
_ = gettext.gettext

CSS = b"""
window { background-color: #16232b; }
.eyebrow {
    color: #4fb6ad;
    font-family: monospace;
    font-size: 11px;
    letter-spacing: 2px;
}
.title { color: #e9e3d6; font-size: 22px; font-weight: bold; }
.subtitle { color: #a9b7bd; font-size: 13px; }
.status-text { color: #e07a5f; font-size: 12px; }
button.tile {
    background-color: #1c2b34;
    background-image: none;
    box-shadow: none;
    border: 1px solid #2f4650;
    border-radius: 10px;
    padding: 14px 18px;
}
button.tile:hover { background-color: #24363f; border-color: #4fb6ad; }
.tile-icon { color: #4fb6ad; font-size: 22px; }
.tile-title { color: #e9e3d6; font-size: 15px; font-weight: bold; }
.tile-desc { color: #a9b7bd; font-size: 12px; }
"""

# (title, description, icon-name candidates, fallback glyph, command)
# Translate deliberately points at the same command as Ask -- there's no
# separate translate tool yet, just the assistant's own translation
# capability; framed as its own tile since that's a distinct enough need
# to be worth surfacing, not because it's a distinct destination.
TILES = [
    (
        _("Ask"),
        _("Local AI assistant -- questions, help, translation"),
        ("dialog-question-symbolic", "system-help-symbolic"),
        "?",
        ["/usr/local/bin/venu-pacific-assistant"],
    ),
    (
        _("Learn"),
        _("Offline courses and learning materials"),
        ("accessories-dictionary-symbolic", "x-office-presentation-symbolic"),
        "L",
        ["/usr/local/bin/venu-pacific-kolibri"],
    ),
    (
        _("Services"),
        _("Government, health, and education directory"),
        ("folder-documents-symbolic", "system-users-symbolic"),
        "S",
        ["/usr/local/bin/venu-pacific-services-directory"],
    ),
    (
        _("Safety"),
        _("Cyclone, tsunami, and earthquake readiness"),
        ("dialog-warning-symbolic", "software-update-urgent-symbolic"),
        "!",
        ["/usr/local/bin/venu-pacific-disaster-info"],
    ),
    (
        _("Translate"),
        _("Bislama, English, French -- via the AI assistant"),
        ("preferences-desktop-locale-symbolic", "network-transmit-receive-symbolic"),
        "T",
        ["/usr/local/bin/venu-pacific-assistant"],
    ),
]


def _first_available_icon(theme, candidates):
    """First icon name from candidates that actually exists in the
    running icon theme, or None -- icon themes don't all cover every
    freedesktop name, so every tile falls back to a short glyph rather
    than risk a broken-image icon."""
    return next((name for name in candidates if theme.has_icon(name)), None)


class HubWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title=_("Venu Pacific Hub"))
        self.set_default_size(520, 560)
        self.set_position(Gtk.WindowPosition.CENTER)

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.add(outer)

        outer.pack_start(self._build_header(), False, False, 0)

        tiles_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        tiles_box.set_border_width(24)
        for title, desc, icon_candidates, fallback, command in TILES:
            tiles_box.pack_start(
                self._build_tile(title, desc, icon_candidates, fallback, command),
                False, False, 0,
            )
        outer.pack_start(tiles_box, True, True, 0)

        # set_border_width() is a Gtk.Container method -- Gtk.Label isn't
        # one, confirmed live (AttributeError, caught from a real
        # terminal run, not something the syntax-only checks done before
        # this shipped could have caught). Margins are the correct,
        # widget-level equivalent, valid on any Gtk.Widget.
        self.status_label = Gtk.Label(label="", xalign=0.5, wrap=True)
        self.status_label.get_style_context().add_class("status-text")
        self.status_label.set_margin_start(12)
        self.status_label.set_margin_end(12)
        self.status_label.set_margin_top(6)
        self.status_label.set_margin_bottom(12)
        outer.pack_start(self.status_label, False, False, 0)

    def _build_header(self):
        header = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        header.set_border_width(28)

        if os.path.exists(LOGO_PATH):
            pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(LOGO_PATH, 56, 56, True)
            image = Gtk.Image.new_from_pixbuf(pixbuf)
            image.set_halign(Gtk.Align.CENTER)
            header.pack_start(image, False, False, 0)

        eyebrow = Gtk.Label(label="VENU PACIFIC", xalign=0.5)
        eyebrow.get_style_context().add_class("eyebrow")
        header.pack_start(eyebrow, False, False, 0)

        title = Gtk.Label(label=_("Hub"), xalign=0.5)
        title.get_style_context().add_class("title")
        header.pack_start(title, False, False, 0)

        subtitle = Gtk.Label(
            label=_("Offline learning, services, safety information, and AI assistance."),
            xalign=0.5,
            wrap=True,
            justify=Gtk.Justification.CENTER,
        )
        subtitle.get_style_context().add_class("subtitle")
        header.pack_start(subtitle, False, False, 4)

        return header

    def _build_tile(self, title, desc, icon_candidates, fallback, command):
        button = Gtk.Button()
        button.get_style_context().add_class("tile")
        button.connect("clicked", self._on_tile_clicked, title, command)

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=16)

        theme = Gtk.IconTheme.get_default()
        icon_name = _first_available_icon(theme, icon_candidates)
        icon_widget = (
            Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.DND)
            if icon_name
            else Gtk.Label(label=fallback)
        )
        if icon_name is None:
            icon_widget.get_style_context().add_class("tile-icon")
        icon_widget.set_valign(Gtk.Align.CENTER)
        row.pack_start(icon_widget, False, False, 0)

        text_col = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        title_label = Gtk.Label(label=title, xalign=0)
        title_label.get_style_context().add_class("tile-title")
        text_col.pack_start(title_label, False, False, 0)
        desc_label = Gtk.Label(label=desc, xalign=0, wrap=True)
        desc_label.get_style_context().add_class("tile-desc")
        text_col.pack_start(desc_label, False, False, 0)
        row.pack_start(text_col, True, True, 0)

        button.add(row)
        return button

    def _on_tile_clicked(self, _button, title, command):
        self.status_label.set_text("")
        try:
            subprocess.Popen(command)
        except OSError as exc:
            # Shouldn't happen on a properly built image -- every command
            # here points at another app this same image ships -- but
            # never fail silently if it somehow does.
            self.status_label.set_text(
                _("Could not open {name}: {error}").format(name=title, error=exc)
            )


def main():
    provider = Gtk.CssProvider()
    provider.load_from_data(CSS)
    Gtk.StyleContext.add_provider_for_screen(
        Gdk.Screen.get_default(),
        provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
    )

    win = HubWindow()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()


if __name__ == "__main__":
    main()
