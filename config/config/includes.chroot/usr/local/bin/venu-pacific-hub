#!/usr/bin/env python3
"""Venu Pacific Hub -- single entry-point launcher.

Not a rewrite or a merge of the existing apps -- each tile below just
launches the app that already does that job (venu-pacific-assistant,
venu-pacific-kolibri, venu-pacific-services-directory,
venu-pacific-disaster-info). Deliberately thin: almost no logic here to
get wrong, since all the real functionality already works independently.
Kept as a separate optional entry point rather than replacing the
individual apps' own menu entries -- both stay visible, so nothing about
opening an app directly regresses.

Safety (disaster-info) and Services (services-directory) launch their own
fast, AI-independent apps directly rather than being folded into the
assistant's window -- that's deliberate: emergency safety info needs to
stay usable even if the AI/LLM component is slow to start, crashed, or
never launched at all. See ROADMAP.md's "one app vs several" discussion
for the full reasoning.

UI chrome strings are gettext-wrapped under the "venu-pacific-hub" domain
(kept separate from the other apps' domains so catalogs stay
independently sized, same convention used throughout this project).
"""

import gettext
import os
import subprocess

import gi

gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
from gi.repository import Gdk, GdkPixbuf, Gtk  # noqa: E402

LOGO_PATH = "/usr/share/pixmaps/venu-pacific.png"

gettext.bindtextdomain("venu-pacific-hub", "/usr/share/locale")
gettext.textdomain("venu-pacific-hub")
_ = gettext.gettext

CSS = b"""
window { background-color: #16232b; }
/* Header gets a subtle vertical gradient instead of a flat block --
   GTK3 CSS supports linear-gradient, confirmed by parse test. */
.header-area {
    background-image: linear-gradient(to bottom, #101a21, #16232b);
}
.eyebrow {
    color: #4fb6ad;
    font-family: monospace;
    font-size: 11px;
    letter-spacing: 2px;
}
.subtitle { color: #8fa0a7; font-size: 12.5px; }
.status-text { color: #e07a5f; font-size: 12px; }
.footer-text {
    color: #4a5a63;
    font-family: monospace;
    font-size: 10px;
    letter-spacing: 1px;
}
/* Tiles: card-style buttons with a slow-ish hover transition -- GTK3
   CSS supports `transition`, so hover feels deliberate, not abrupt. */
button.tile {
    background-color: #1c2b34;
    background-image: none;
    box-shadow: none;
    border: 1px solid #2f4650;
    border-radius: 12px;
    padding: 16px;
    transition: background-color 150ms ease, border-color 150ms ease;
}
button.tile:hover { background-color: #22333d; }
button.tile:focus { border-color: #4fb6ad; }
.tile-title { color: #e9e3d6; font-size: 15px; font-weight: bold; }
.tile-desc { color: #8fa0a7; font-size: 11.5px; }
.hero-title { color: #ffffff; font-size: 18px; font-weight: bold; }
.hero-desc { color: #a9b7bd; font-size: 12.5px; }
/* Icon chips: a rounded square behind each tile's symbolic icon.
   Symbolic icons take their color from CSS `color`, so each chip class
   tints both its background and its icon from one accent. Accents stay
   inside the existing brand palette (teal / coral / sand / ocean). */
.chip {
    border-radius: 10px;
    min-width: 44px;
    min-height: 44px;
}
.chip-ask      { background-color: rgba(79, 182, 173, 0.16); color: #4fb6ad; }
.chip-learn    { background-color: rgba(233, 227, 214, 0.12); color: #e9e3d6; }
.chip-services { background-color: rgba(79, 140, 182, 0.16); color: #6aa8cc; }
.chip-safety   { background-color: rgba(224, 122, 95, 0.16); color: #e07a5f; }
.chip-translate{ background-color: rgba(184, 95, 44, 0.18); color: #cf8a5a; }
button.tile:hover .chip-ask      { background-color: rgba(79, 182, 173, 0.28); }
button.tile:hover .chip-learn    { background-color: rgba(233, 227, 214, 0.22); }
button.tile:hover .chip-services { background-color: rgba(79, 140, 182, 0.28); }
button.tile:hover .chip-safety   { background-color: rgba(224, 122, 95, 0.28); }
button.tile:hover .chip-translate{ background-color: rgba(184, 95, 44, 0.30); }
"""

# (title, description, icon-name candidates, fallback glyph, chip css
# class, command). Translate deliberately points at the same command as
# Ask -- there's no separate translate tool yet, just the assistant's own
# translation capability; framed as its own tile since that's a distinct
# enough need to be worth surfacing, not because it's a distinct
# destination.
#
# Ask is the "hero" tile (full width, larger) -- it's the flagship
# feature, and giving it visual primacy also gives the grid below a
# clear reading order instead of five identical rows.
HERO_TILE = (
    _("Ask"),
    _("Local AI assistant -- questions, help, and translation, fully offline"),
    ("dialog-question-symbolic", "system-help-symbolic"),
    "?",
    "chip-ask",
    ["/usr/local/bin/venu-pacific-assistant"],
)

GRID_TILES = [
    (
        _("Learn"),
        _("Offline courses and lessons"),
        ("accessories-dictionary-symbolic", "x-office-presentation-symbolic"),
        "L",
        "chip-learn",
        ["/usr/local/bin/venu-pacific-kolibri"],
    ),
    (
        _("Services"),
        _("Government, health, education"),
        ("folder-documents-symbolic", "system-users-symbolic"),
        "S",
        "chip-services",
        ["/usr/local/bin/venu-pacific-services-directory"],
    ),
    (
        _("Safety"),
        _("Cyclone, tsunami, earthquake"),
        ("dialog-warning-symbolic", "software-update-urgent-symbolic"),
        "!",
        "chip-safety",
        ["/usr/local/bin/venu-pacific-disaster-info"],
    ),
    (
        _("Translate"),
        _("Bislama, English, French"),
        ("preferences-desktop-locale-symbolic", "network-transmit-receive-symbolic"),
        "T",
        "chip-translate",
        ["/usr/local/bin/venu-pacific-assistant"],
    ),
]


def _first_available_icon(theme, candidates):
    """First icon name from candidates that actually exists in the
    running icon theme, or None -- icon themes don't all cover every
    freedesktop name, so every tile falls back to a short glyph rather
    than risk a broken-image icon."""
    return next((name for name in candidates if theme.has_icon(name)), None)


class HubWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title=_("Venu Pacific Hub"))
        self.set_default_size(560, 640)
        self.set_position(Gtk.WindowPosition.CENTER)

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.add(outer)

        outer.pack_start(self._build_header(), False, False, 0)

        # Hero (full-width Ask, the flagship) above a 2x2 grid of the
        # other four -- clear reading order instead of five identical
        # rows. Homogeneous grid columns keep the pairs equal width.
        tiles_area = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        tiles_area.set_border_width(24)

        title, desc, icons, fallback, chip, command = HERO_TILE
        tiles_area.pack_start(
            self._build_tile(title, desc, icons, fallback, chip, command, hero=True),
            False, False, 0,
        )

        grid = Gtk.Grid()
        grid.set_row_spacing(12)
        grid.set_column_spacing(12)
        grid.set_column_homogeneous(True)
        for index, (title, desc, icons, fallback, chip, command) in enumerate(GRID_TILES):
            tile = self._build_tile(title, desc, icons, fallback, chip, command)
            grid.attach(tile, index % 2, index // 2, 1, 1)
        tiles_area.pack_start(grid, False, False, 0)

        outer.pack_start(tiles_area, True, True, 0)

        # set_border_width() is a Gtk.Container method -- Gtk.Label isn't
        # one, confirmed live (AttributeError, caught from a real
        # terminal run, not something the syntax-only checks done before
        # this shipped could have caught). Margins are the correct,
        # widget-level equivalent, valid on any Gtk.Widget.
        self.status_label = Gtk.Label(label="", xalign=0.5, wrap=True)
        self.status_label.get_style_context().add_class("status-text")
        self.status_label.set_margin_start(12)
        self.status_label.set_margin_end(12)
        self.status_label.set_margin_top(6)
        self.status_label.set_margin_bottom(4)
        outer.pack_start(self.status_label, False, False, 0)

        footer = Gtk.Label(label=_("VENU PACIFIC — OFFLINE FIRST"), xalign=0.5)
        footer.get_style_context().add_class("footer-text")
        footer.set_margin_bottom(12)
        outer.pack_start(footer, False, False, 0)

    def _build_header(self):
        header = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        header.get_style_context().add_class("header-area")
        header.set_border_width(26)

        if os.path.exists(LOGO_PATH):
            pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(LOGO_PATH, 64, 64, True)
            image = Gtk.Image.new_from_pixbuf(pixbuf)
            image.set_halign(Gtk.Align.CENTER)
            header.pack_start(image, False, False, 0)

        eyebrow = Gtk.Label(label="VENU PACIFIC", xalign=0.5)
        eyebrow.get_style_context().add_class("eyebrow")
        header.pack_start(eyebrow, False, False, 2)

        subtitle = Gtk.Label(
            label=_("Learning, services, safety, and AI assistance — all offline."),
            xalign=0.5,
            wrap=True,
            justify=Gtk.Justification.CENTER,
        )
        subtitle.get_style_context().add_class("subtitle")
        header.pack_start(subtitle, False, False, 2)

        return header

    def _build_tile(self, title, desc, icon_candidates, fallback, chip_class, command, hero=False):
        button = Gtk.Button()
        button.get_style_context().add_class("tile")
        button.connect("clicked", self._on_tile_clicked, title, command)

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=14)

        # Icon inside a tinted rounded chip -- symbolic icons take their
        # color from CSS `color`, so the chip class tints both at once.
        theme = Gtk.IconTheme.get_default()
        icon_name = _first_available_icon(theme, icon_candidates)
        icon_size = Gtk.IconSize.DIALOG if hero else Gtk.IconSize.LARGE_TOOLBAR
        icon_widget = (
            Gtk.Image.new_from_icon_name(icon_name, icon_size)
            if icon_name
            else Gtk.Label(label=fallback)
        )
        chip = Gtk.Box()
        chip.get_style_context().add_class("chip")
        chip.get_style_context().add_class(chip_class)
        chip.set_halign(Gtk.Align.CENTER)
        chip.set_valign(Gtk.Align.CENTER)
        icon_widget.set_halign(Gtk.Align.CENTER)
        icon_widget.set_valign(Gtk.Align.CENTER)
        icon_widget.set_hexpand(True)
        icon_widget.set_vexpand(True)
        chip.add(icon_widget)
        row.pack_start(chip, False, False, 0)

        text_col = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        text_col.set_valign(Gtk.Align.CENTER)
        title_label = Gtk.Label(label=title, xalign=0)
        title_label.get_style_context().add_class("hero-title" if hero else "tile-title")
        text_col.pack_start(title_label, False, False, 0)
        desc_label = Gtk.Label(label=desc, xalign=0, wrap=True)
        desc_label.get_style_context().add_class("hero-desc" if hero else "tile-desc")
        text_col.pack_start(desc_label, False, False, 0)
        row.pack_start(text_col, True, True, 0)

        button.add(row)
        return button

    def _on_tile_clicked(self, _button, title, command):
        self.status_label.set_text("")
        try:
            subprocess.Popen(command)
        except OSError as exc:
            # Shouldn't happen on a properly built image -- every command
            # here points at another app this same image ships -- but
            # never fail silently if it somehow does.
            self.status_label.set_text(
                _("Could not open {name}: {error}").format(name=title, error=exc)
            )


def main():
    provider = Gtk.CssProvider()
    provider.load_from_data(CSS)
    Gtk.StyleContext.add_provider_for_screen(
        Gdk.Screen.get_default(),
        provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
    )

    win = HubWindow()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()


if __name__ == "__main__":
    main()
