#!/usr/bin/env python3
"""Venu Pacific disaster-readiness app.

Offline cyclone/tsunami/earthquake safety info and emergency contacts,
launched on demand from the applications menu or desktop icon (not
autostarted — this is a reference tool, not a first-run notice).

Per-country content lives in content/<country>.json (installed to
/usr/share/venu-pacific/disaster-info/) rather than being hardcoded here,
so adding a country is a content task, not an engineering one — same
principle as the gettext translation framework. See content/README.md for
the schema and how to add a country.

UI chrome strings are gettext-wrapped under the "venu-pacific-disaster"
domain (kept separate from the welcome app's "venu-pacific" domain so the
catalogs stay independently sized as more countries are added). The
per-country JSON content itself is English-only for v1 -- translating it
is a separate future task, since xgettext can't extract strings out of
JSON content the way it does Python source.
"""

import gettext
import json
import os

import gi

gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
from gi.repository import Gdk, GdkPixbuf, Gtk  # noqa: E402

LOGO_PATH = "/usr/share/pixmaps/venu-pacific.png"
CONTENT_DIR = "/usr/share/venu-pacific/disaster-info"

gettext.bindtextdomain("venu-pacific-disaster", "/usr/share/locale")
gettext.textdomain("venu-pacific-disaster")
_ = gettext.gettext

CSS = b"""
window { background-color: #16232b; }
.eyebrow {
    color: #4fb6ad;
    font-family: monospace;
    font-size: 11px;
    letter-spacing: 2px;
}
.title { color: #e9e3d6; font-size: 22px; font-weight: bold; }
.section-title { color: #e9e3d6; font-size: 14px; font-weight: bold; }
.body-text { color: #a9b7bd; font-size: 13px; }
.contact-number { color: #ffffff; font-weight: bold; font-size: 13px; }
.source-text { color: #6b7880; font-size: 11px; }
expander { color: #e9e3d6; font-weight: bold; }
"""


def _load_countries():
    countries = {}
    if not os.path.isdir(CONTENT_DIR):
        return countries
    for filename in sorted(os.listdir(CONTENT_DIR)):
        if not filename.endswith(".json"):
            continue
        path = os.path.join(CONTENT_DIR, filename)
        with open(path, encoding="utf-8") as f:
            data = json.load(f)
        countries[data["name"]] = data
    return countries


class DisasterInfoWindow(Gtk.Window):
    def __init__(self, countries):
        super().__init__(title=_("Venu Pacific — Disaster Readiness"))
        self.countries = countries
        self.set_default_size(620, 680)
        self.set_position(Gtk.WindowPosition.CENTER)

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.add(outer)

        outer.pack_start(self._build_header(), False, False, 0)

        self.content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=18)
        self.content_box.set_border_width(28)

        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroller.add(self.content_box)
        outer.pack_start(scroller, True, True, 0)

        if self.countries:
            self._show_country(next(iter(self.countries)))
        else:
            self._show_no_content()

    def _build_header(self):
        header = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        header.set_border_width(28)

        if os.path.exists(LOGO_PATH):
            pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(
                LOGO_PATH, 56, 56, True
            )
            header.pack_start(Gtk.Image.new_from_pixbuf(pixbuf), False, False, 0)

        eyebrow = Gtk.Label(label="VENU PACIFIC", xalign=0.5)
        eyebrow.get_style_context().add_class("eyebrow")
        header.pack_start(eyebrow, False, False, 0)

        title = Gtk.Label(label=_("Disaster Readiness"), xalign=0.5)
        title.get_style_context().add_class("title")
        header.pack_start(title, False, False, 0)

        if self.countries:
            selector = Gtk.ComboBoxText()
            for name in self.countries:
                selector.append(name, name)
            selector.set_active(0)
            selector.connect("changed", self._on_country_changed)
            selector.set_halign(Gtk.Align.CENTER)
            header.pack_start(selector, False, False, 6)

        return header

    def _on_country_changed(self, combo):
        name = combo.get_active_text()
        if name:
            self._show_country(name)

    def _show_no_content(self):
        label = Gtk.Label(
            label=_(
                "No disaster-readiness content is installed on this system."
            ),
            wrap=True,
            xalign=0,
        )
        label.get_style_context().add_class("body-text")
        self.content_box.pack_start(label, False, False, 0)
        self.content_box.show_all()

    def _clear_content(self):
        for child in self.content_box.get_children():
            self.content_box.remove(child)

    def _show_country(self, name):
        self._clear_content()
        data = self.countries[name]

        self.content_box.pack_start(
            self._build_contacts_section(data), False, False, 0
        )

        for hazard_key, hazard in data.get("hazards", {}).items():
            self.content_box.pack_start(
                self._build_hazard_section(hazard), False, False, 0
            )

        sources = data.get("sources", [])
        if sources:
            self.content_box.pack_start(
                self._build_sources_section(sources), False, False, 0
            )

        self.content_box.show_all()

    def _build_contacts_section(self, data):
        section = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)

        section_title = Gtk.Label(label=_("Emergency contacts"), xalign=0)
        section_title.get_style_context().add_class("section-title")
        section.pack_start(section_title, False, False, 0)

        for contact in data.get("emergency_contacts", []):
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)

            # Service names vary a lot in length ("Fire" vs "Pro Medical
            # (private ambulance service)") -- wrap rather than truncate or
            # force a fixed column width.
            service_label = Gtk.Label(label=contact["service"], xalign=0, wrap=True)
            service_label.get_style_context().add_class("body-text")
            service_label.set_max_width_chars(32)
            row.pack_start(service_label, True, True, 0)

            number_label = Gtk.Label(label=contact["number"], xalign=1)
            number_label.get_style_context().add_class("contact-number")
            row.pack_start(number_label, False, False, 0)

            section.pack_start(row, False, False, 0)

        return section

    def _build_hazard_section(self, hazard):
        expander = Gtk.Expander(label=hazard["label"])
        expander.set_expanded(False)

        inner = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        inner.set_border_width(12)

        for phase_key, phase_label in (
            ("before", _("Before")),
            ("during", _("During")),
            ("after", _("After")),
        ):
            items = hazard.get(phase_key)
            if not items:
                continue

            phase_title = Gtk.Label(label=phase_label, xalign=0)
            phase_title.get_style_context().add_class("section-title")
            inner.pack_start(phase_title, False, False, 0)

            for item in items:
                item_label = Gtk.Label(
                    label=f"•  {item}", wrap=True, xalign=0
                )
                item_label.get_style_context().add_class("body-text")
                inner.pack_start(item_label, False, False, 0)

        expander.add(inner)
        return expander

    def _build_sources_section(self, sources):
        section = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        title = Gtk.Label(label=_("Sources"), xalign=0)
        title.get_style_context().add_class("section-title")
        section.pack_start(title, False, False, 0)

        for source in sources:
            link = Gtk.LinkButton.new_with_label(
                source["url"], source["label"]
            )
            link.set_halign(Gtk.Align.START)
            link.get_style_context().add_class("source-text")
            section.pack_start(link, False, False, 0)

        return section


def main():
    provider = Gtk.CssProvider()
    provider.load_from_data(CSS)
    Gtk.StyleContext.add_provider_for_screen(
        Gdk.Screen.get_default(),
        provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
    )

    countries = _load_countries()
    win = DisasterInfoWindow(countries)
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()


if __name__ == "__main__":
    main()
