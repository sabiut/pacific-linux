#!/usr/bin/env python3
"""Venu Pacific first-run welcome app.

Shows once per user (guarded by a marker file, same pattern as
venu-pacific-set-defaults) via an XDG autostart entry. Strings are
gettext-wrapped and the catalogs live under locales/<lang>/venu-pacific.po.
English and Bislama both have real, reviewed translations as of Phase 2 --
see locales/bi/venu-pacific.po.
"""

import gettext
import os

import gi

gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
from gi.repository import Gdk, GdkPixbuf, Gtk  # noqa: E402

MARKER = os.path.expanduser("~/.config/venu-pacific/.welcome-shown")
LOGO_PATH = "/usr/share/pixmaps/venu-pacific.png"

# Catalogs are compiled into /usr/share/locale by
# 0140-venu-pacific-locales.hook.chroot from locales/<lang>/venu-pacific.po.
# Picks up the running desktop session's LANGUAGE/LC_ALL/LANG automatically.
gettext.bindtextdomain("venu-pacific", "/usr/share/locale")
gettext.textdomain("venu-pacific")

CURRENT_LANG = (os.environ.get("LANGUAGE", "").split(":")[0]) or "en"


def _set_translation(lang_code):
    """Rebind the module-level `_` so newly-built widgets render in lang_code.

    Bislama has no glibc locale (no bi_VU), so this can't rely on LC_ALL --
    gettext.translation() works directly off the catalog files regardless.
    """
    global _, CURRENT_LANG
    CURRENT_LANG = lang_code
    if lang_code == "en":
        _ = gettext.NullTranslations().gettext
        return
    try:
        _ = gettext.translation(
            "venu-pacific", localedir="/usr/share/locale", languages=[lang_code]
        ).gettext
    except FileNotFoundError:
        _ = gettext.NullTranslations().gettext


def _persist_language(lang_code):
    """Make the choice stick after the welcome window closes.

    ~/.config/environment.d/ is read by pam_systemd at login (confirmed wired
    into lightdm's PAM stack via common-session) -- this is what applies the
    language to XFCE and every other gettext-aware app, not just this window.
    """
    env_dir = os.path.expanduser("~/.config/environment.d")
    os.makedirs(env_dir, exist_ok=True)
    env_file = os.path.join(env_dir, "50-venu-pacific-language.conf")
    if lang_code == "en":
        if os.path.exists(env_file):
            os.remove(env_file)
    else:
        with open(env_file, "w") as f:
            f.write(f"LANGUAGE={lang_code}\n")


_set_translation(CURRENT_LANG)

CSS = b"""
window { background-color: #16232b; }
.eyebrow {
    color: #4fb6ad;
    font-family: monospace;
    font-size: 11px;
    letter-spacing: 2px;
}
.title { color: #e9e3d6; font-size: 22px; font-weight: bold; }
.section-title { color: #e9e3d6; font-size: 14px; font-weight: bold; }
.body-text { color: #a9b7bd; font-size: 13px; }
/* The radio buttons below have no class of their own, so without this
 * their label text falls back to the desktop theme's default label
 * color -- normally fine, but against this window's custom dark
 * background it renders as low-contrast dark-on-dark (same root cause
 * as the button fix below, just for radiobutton instead of button). */
radiobutton { color: #e9e3d6; }
/* background-image/box-shadow/border resets are needed because the
 * desktop theme's default button styling paints a gradient over plain
 * background-color -- without these the theme's gradient shows through
 * instead of our teal, leaving white text on a near-white button. */
button.get-started {
    background-color: #1f6f74;
    background-image: none;
    box-shadow: none;
    border: none;
    text-shadow: none;
    color: #ffffff;
    font-weight: bold;
    border-radius: 6px;
    padding: 8px 24px;
}
button.get-started:hover {
    background-color: #4fb6ad;
    background-image: none;
}
"""


def _highlights():
    return [
        ("Firefox", _("Web browsing")),
        ("LibreOffice", _("Documents, spreadsheets, presentations")),
        ("GIMP", _("Image editing")),
        (
            "Kiwix",
            _(
                "Offline Wikipedia and Pacific health/agriculture/disaster info. "
                "Works with no internet connection"
            ),
        ),
        ("Synaptic", _("Install or remove software")),
    ]


class WelcomeWindow(Gtk.Window):
    def __init__(self, on_language_change):
        super().__init__(title=_("Welcome to Venu Pacific"))
        self.on_language_change = on_language_change
        self.set_default_size(560, 560)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_resizable(False)
        # delete-event (not destroy) so on_dismiss doesn't fire when a
        # language switch destroys this window to rebuild a fresh one.
        self.connect("delete-event", self.on_dismiss)

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.add(outer)

        outer.pack_start(self._build_header(), False, False, 0)

        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroller.add(self._build_body())
        outer.pack_start(scroller, True, True, 0)

        outer.pack_start(self._build_footer(), False, False, 0)

    def _build_header(self):
        header = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        header.set_border_width(28)

        if os.path.exists(LOGO_PATH):
            pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(
                LOGO_PATH, 72, 72, True
            )
            header.pack_start(Gtk.Image.new_from_pixbuf(pixbuf), False, False, 0)

        eyebrow = Gtk.Label(label="VENU PACIFIC", xalign=0.5)
        eyebrow.get_style_context().add_class("eyebrow")
        header.pack_start(eyebrow, False, False, 0)

        title = Gtk.Label(label=_("Welcome"), xalign=0.5)
        title.get_style_context().add_class("title")
        header.pack_start(title, False, False, 0)

        return header

    def _build_body(self):
        body = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=18)
        body.set_border_width(28)

        intro = Gtk.Label(
            label=_(
                "A Debian-based desktop built for the Pacific Islands region, "
                "designed for real conditions here: limited bandwidth, older "
                "hardware, and routine cyclone/tsunami/earthquake exposure."
            ),
            wrap=True,
            xalign=0,
        )
        intro.get_style_context().add_class("body-text")
        body.pack_start(intro, False, False, 0)

        body.pack_start(self._build_language_section(), False, False, 0)
        body.pack_start(self._build_highlights_section(), False, False, 0)

        return body

    def _build_language_section(self):
        section = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)

        section_title = Gtk.Label(label=_("Language"), xalign=0)
        section_title.get_style_context().add_class("section-title")
        section.pack_start(section_title, False, False, 0)

        english = Gtk.RadioButton.new_with_label(None, _("English"))
        english.set_active(CURRENT_LANG != "bi")
        section.pack_start(english, False, False, 0)

        bislama = Gtk.RadioButton.new_with_label_from_widget(
            english,
            _("Bislama"),
        )
        bislama.set_active(CURRENT_LANG == "bi")
        section.pack_start(bislama, False, False, 0)

        english.connect("toggled", self._on_language_toggled, "en")
        bislama.connect("toggled", self._on_language_toggled, "bi")

        return section

    def _on_language_toggled(self, button, lang_code):
        if not button.get_active() or lang_code == CURRENT_LANG:
            return
        _persist_language(lang_code)
        _set_translation(lang_code)
        self.on_language_change()

    def _build_highlights_section(self):
        section = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)

        section_title = Gtk.Label(label=_("What's included"), xalign=0)
        section_title.get_style_context().add_class("section-title")
        section.pack_start(section_title, False, False, 0)

        for name, desc in _highlights():
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)

            name_label = Gtk.Label(label=f"{name}:", xalign=0)
            name_label.get_style_context().add_class("body-text")
            name_label.set_width_chars(12)
            row.pack_start(name_label, False, False, 0)

            desc_label = Gtk.Label(label=desc, xalign=0, wrap=True)
            desc_label.get_style_context().add_class("body-text")
            row.pack_start(desc_label, True, True, 0)

            section.pack_start(row, False, False, 0)

        return section

    def _build_footer(self):
        footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        footer.set_border_width(20)
        footer.set_halign(Gtk.Align.END)

        get_started = Gtk.Button(label=_("Get Started"))
        get_started.get_style_context().add_class("get-started")
        get_started.connect("clicked", self.on_dismiss)
        footer.pack_start(get_started, False, False, 0)

        return footer

    def on_dismiss(self, *_args):
        os.makedirs(os.path.dirname(MARKER), exist_ok=True)
        open(MARKER, "a").close()
        Gtk.main_quit()
        return False


def main():
    if os.path.exists(MARKER):
        return

    provider = Gtk.CssProvider()
    provider.load_from_data(CSS)
    Gtk.StyleContext.add_provider_for_screen(
        Gdk.Screen.get_default(),
        provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
    )

    state = {"win": None}

    def show_window():
        if state["win"] is not None:
            state["win"].destroy()
        win = WelcomeWindow(on_language_change=show_window)
        state["win"] = win
        win.show_all()

    show_window()
    Gtk.main()


if __name__ == "__main__":
    main()
