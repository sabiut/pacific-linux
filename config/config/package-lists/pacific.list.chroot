# Pacific Linux — Phase 1 MVP package set
# One package name per line. Verified against the trixie repos on 2026-07-20.

# Desktop — XFCE (task-xfce-desktop pulls in xfce4, lightdm, and friends).
# task-xfce-desktop pulls trixie's stock xfdesktop4 4.20.1-1, which has a
# confirmed wallpaper-rendering bug — see
# config/hooks/normal/0120-pacific-linux-xfdesktop-fix.hook.chroot, which
# replaces it with 4.20.2 after packages are installed.
task-xfce-desktop

# wget needed by the xfdesktop4 fix-up hook above to fetch the two .deb
# files directly (not added as an ongoing apt source — see the hook for why).
wget

# Boot splash — themed via config/hooks/normal/0100-pacific-linux-plymouth.hook.chroot
# (our own theme ships via includes.chroot below; plymouth-themes isn't
# needed and would just add unused theme files to the image)
plymouth

# Icon theme — chose an existing, maintained theme instead of building a
# custom icon set from scratch; that's a much larger effort than Phase 1
# branding calls for. Papirus is actively maintained, GTK/XFCE-friendly, and
# light enough for older hardware.
papirus-icon-theme

# Browser
firefox-esr

# Office / creative
libreoffice
gimp

# Offline knowledge (Kiwix — offline Wikipedia/content reader)
kiwix

# Installer (present in the live image so the target machine can install to
# disk). The `calamares` package is only the framework — with nothing else,
# there's no /etc/calamares/settings.conf or module sequence, so it can't
# actually install anything. calamares-settings-debian provides Debian's
# real settings/branding/module config; confirmed by inspecting a built
# image's squashfs (usr/bin/calamares present, /etc/calamares absent
# entirely) before this was added.
calamares
calamares-settings-debian

# Software center — Synaptic. Chose it over GNOME Software: no PackageKit
# or GNOME-stack dependency, fits the low-spec-hardware constraint, and
# it's a mature, direct apt front-end (install/remove/search/upgrade) that
# needs no custom UI work for Phase 1.
synaptic

# Update manager (notify-send is the notification backend for
# pacific-linux-notify-updates, see config/config/includes.chroot)
libnotify-bin

# Welcome app (welcome-app/pacific-linux-welcome) — GTK3 via PyGObject,
# not GTK4: XFCE's own native apps here are still GTK3 (confirmed:
# xfdesktop 4.20 reports "Built with GTK+ 3.24"), so this matches rather
# than adding a second GTK stack for one small first-run window.
python3-gi
gir1.2-gtk-3.0

# VM guest integration — spice-vdagent enables host<->guest clipboard
# sharing and display resizing under SPICE (virt-manager); qemu-guest-agent
# lets the host query/manage the guest (graceful shutdown, IP reporting).
# Both are inert on real hardware: they only activate when the matching
# virtio devices are detected, so they cost nothing outside a VM.
spice-vdagent
qemu-guest-agent

# NOTE: VS Code / VSCodium from the roadmap is deferred — neither ships in
# Debian's own repos, so including it means adding a third-party apt archive
# (config/archives/) and trusting its signing key. Revisit once we decide
# whether that's worth the added dependency, or ship python3-idle instead.
