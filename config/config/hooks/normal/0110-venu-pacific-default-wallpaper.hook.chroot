#!/bin/sh
# Registers our wallpaper as the system-wide Debian desktop-base default
# background, at a higher priority than desktop-base's stock themes
# (ceratopsian-theme ships at priority 65 in trixie — see
# `update-alternatives --display desktop-background`).
#
# This is the standard Debian mechanism derivative distros use to rebrand
# the default look: /usr/share/images/desktop-base/desktop-background is
# the well-known path other tooling reads, resolved via update-alternatives.
#
# Added after boot-testing showed that setting the wallpaper via per-user
# xfconf properties (venu-pacific-set-defaults) writes correctly but does
# not make xfdesktop visually repaint — confirmed on both a QEMU/KVM VM and
# real hardware. This system-wide default is a second, independent
# mechanism that doesn't depend on xfdesktop noticing a runtime property
# change at all. Kept the xfconf script too, since it's still correct to
# have the per-monitor properties match what's actually shown.

set -e

update-alternatives --install \
    /usr/share/images/desktop-base/desktop-background \
    desktop-background \
    /usr/share/backgrounds/venu-pacific/pacific-ocean.png \
    100
