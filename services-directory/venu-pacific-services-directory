#!/usr/bin/env python3
"""Venu Pacific services directory app.

Offline reference for government e-services, health facilities, and
education resources, launched on demand from the applications menu (not
autostarted -- a reference tool, not a first-run notice).

Per-country content lives in content/<country>.json (installed to
/usr/share/venu-pacific/services-directory/) rather than being hardcoded
here, so adding a country is a content task, not an engineering one -- same
principle as disaster-info/ and the gettext translation framework. See
content/README.md for the schema and how to add a country.

UI chrome strings are gettext-wrapped under the "venu-pacific-services"
domain (kept separate from the welcome app's and disaster-info's domains
so the catalogs stay independently sized). The per-country JSON content
itself is English-only for v1, same reasoning as disaster-info/.
"""

import gettext
import json
import os

import gi

gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
from gi.repository import Gdk, GdkPixbuf, Gtk  # noqa: E402

LOGO_PATH = "/usr/share/pixmaps/venu-pacific.png"
CONTENT_DIR = "/usr/share/venu-pacific/services-directory"

gettext.bindtextdomain("venu-pacific-services", "/usr/share/locale")
gettext.textdomain("venu-pacific-services")
_ = gettext.gettext

CSS = b"""
window { background-color: #16232b; }
/* Shared design language with the Hub (hub/venu-pacific-hub): gradient
   header, card sections with soft hover transitions, monospace footer.
   Keep visual changes in step across the three apps. */
.header-area {
    background-image: linear-gradient(to bottom, #101a21, #16232b);
}
.eyebrow {
    color: #4fb6ad;
    font-family: monospace;
    font-size: 11px;
    letter-spacing: 2px;
}
.title { color: #e9e3d6; font-size: 20px; font-weight: bold; }
.section-title { color: #e9e3d6; font-size: 14px; font-weight: bold; }
.body-text { color: #a9b7bd; font-size: 13px; }
.item-name { color: #ffffff; font-weight: bold; font-size: 13px; }
.item-contact { color: #4fb6ad; font-size: 12px; }
.source-text { color: #6b7880; font-size: 11px; }
.footer-text {
    color: #4a5a63;
    font-family: monospace;
    font-size: 10px;
    letter-spacing: 1px;
}
.card {
    background-color: #1c2b34;
    border: 1px solid #2f4650;
    border-radius: 12px;
    padding: 14px;
    transition: background-color 150ms ease;
}
.card:hover { background-color: #22333d; }
expander { color: #e9e3d6; font-weight: bold; }
"""


def _load_countries():
    countries = {}
    if not os.path.isdir(CONTENT_DIR):
        return countries
    for filename in sorted(os.listdir(CONTENT_DIR)):
        if not filename.endswith(".json"):
            continue
        path = os.path.join(CONTENT_DIR, filename)
        with open(path, encoding="utf-8") as f:
            data = json.load(f)
        countries[data["name"]] = data
    return countries


class ServicesDirectoryWindow(Gtk.Window):
    def __init__(self, countries):
        super().__init__(title=_("Venu Pacific — Services Directory"))
        self.countries = countries
        self.set_default_size(640, 700)
        self.set_position(Gtk.WindowPosition.CENTER)

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.add(outer)

        outer.pack_start(self._build_header(), False, False, 0)

        self.content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=18)
        self.content_box.set_border_width(28)

        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroller.add(self.content_box)
        outer.pack_start(scroller, True, True, 0)

        footer = Gtk.Label(label=_("VENU PACIFIC — OFFLINE FIRST"), xalign=0.5)
        footer.get_style_context().add_class("footer-text")
        footer.set_margin_top(6)
        footer.set_margin_bottom(10)
        outer.pack_start(footer, False, False, 0)

        if self.countries:
            self._show_country(next(iter(self.countries)))
        else:
            self._show_no_content()

    def _build_header(self):
        header = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        header.get_style_context().add_class("header-area")
        header.set_border_width(26)

        if os.path.exists(LOGO_PATH):
            pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(
                LOGO_PATH, 64, 64, True
            )
            image = Gtk.Image.new_from_pixbuf(pixbuf)
            image.set_halign(Gtk.Align.CENTER)
            header.pack_start(image, False, False, 0)

        eyebrow = Gtk.Label(label="VENU PACIFIC", xalign=0.5)
        eyebrow.get_style_context().add_class("eyebrow")
        header.pack_start(eyebrow, False, False, 0)

        title = Gtk.Label(label=_("Services Directory"), xalign=0.5)
        title.get_style_context().add_class("title")
        header.pack_start(title, False, False, 0)

        if self.countries:
            selector = Gtk.ComboBoxText()
            for name in self.countries:
                selector.append(name, name)
            selector.set_active(0)
            selector.connect("changed", self._on_country_changed)
            selector.set_halign(Gtk.Align.CENTER)
            header.pack_start(selector, False, False, 6)

        return header

    def _on_country_changed(self, combo):
        name = combo.get_active_text()
        if name:
            self._show_country(name)

    def _show_no_content(self):
        label = Gtk.Label(
            label=_("No services-directory content is installed on this system."),
            wrap=True,
            xalign=0,
        )
        label.get_style_context().add_class("body-text")
        self.content_box.pack_start(label, False, False, 0)
        self.content_box.show_all()

    def _clear_content(self):
        for child in self.content_box.get_children():
            self.content_box.remove(child)

    def _show_country(self, name):
        self._clear_content()
        data = self.countries[name]

        for category_key, category in data.get("categories", {}).items():
            self.content_box.pack_start(
                self._build_category_section(category), False, False, 0
            )

        sources = data.get("sources", [])
        if sources:
            self.content_box.pack_start(
                self._build_sources_section(sources), False, False, 0
            )

        self.content_box.show_all()

    def _build_category_section(self, category):
        # Each category expander sits inside a card so collapsed sections
        # read as tappable units, matching the Hub's tile language.
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        card.get_style_context().add_class("card")

        expander = Gtk.Expander(label=category["label"])
        expander.set_expanded(False)

        inner = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)
        inner.set_border_width(12)

        for item in category.get("items", []):
            item_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)

            name_label = Gtk.Label(label=item["name"], xalign=0, wrap=True)
            name_label.get_style_context().add_class("item-name")
            item_box.pack_start(name_label, False, False, 0)

            if item.get("description"):
                desc_label = Gtk.Label(
                    label=item["description"], xalign=0, wrap=True
                )
                desc_label.get_style_context().add_class("body-text")
                item_box.pack_start(desc_label, False, False, 0)

            contact_bits = [
                item[k]
                for k in ("agency", "location", "contact")
                if item.get(k)
            ]
            if contact_bits:
                contact_label = Gtk.Label(
                    label=" · ".join(contact_bits), xalign=0, wrap=True
                )
                contact_label.get_style_context().add_class("item-contact")
                item_box.pack_start(contact_label, False, False, 0)

            inner.pack_start(item_box, False, False, 0)

        expander.add(inner)
        card.pack_start(expander, False, False, 0)
        return card

    def _build_sources_section(self, sources):
        section = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        section.get_style_context().add_class("card")
        title = Gtk.Label(label=_("Sources"), xalign=0)
        title.get_style_context().add_class("section-title")
        section.pack_start(title, False, False, 0)

        for source in sources:
            link = Gtk.LinkButton.new_with_label(
                source["url"], source["label"]
            )
            link.set_halign(Gtk.Align.START)
            link.get_style_context().add_class("source-text")
            section.pack_start(link, False, False, 0)

        return section


def main():
    provider = Gtk.CssProvider()
    provider.load_from_data(CSS)
    Gtk.StyleContext.add_provider_for_screen(
        Gdk.Screen.get_default(),
        provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
    )

    countries = _load_countries()
    win = ServicesDirectoryWindow(countries)
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()


if __name__ == "__main__":
    main()
