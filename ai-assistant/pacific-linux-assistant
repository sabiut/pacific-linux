def query_assistant(user_text, history, request_approval):
    # /no_think keeps interactive replies fast -- reasoning mode is useful
    # for the translation post-editing prototype but too slow for chat.
    messages = (
        [{"role": "system", "content": SYSTEM_PROMPT}]
        + history
        + [{"role": "user", "content": user_text + "\n\n/no_think"}]
    )

    for _round in range(3):  # cap rounds so a confused model can't loop forever
        payload = {"messages": messages, "tools": TOOLS, "temperature": 0.3, "max_tokens": 500}
        req = urllib.request.Request(
            f"{SERVER_URL}/v1/chat/completions",
            data=json.dumps(payload).encode(),
            headers={"Content-Type": "application/json"},
        )
        with urllib.request.urlopen(req, timeout=120) as resp:
            data = json.loads(resp.read())
        message = data["choices"][0]["message"]
        tool_calls = message.get("tool_calls")
        if not tool_calls:
            return (message.get("content") or "").strip()

        messages.append(message)
        for call in tool_calls:
            name = call["function"]["name"]
            call_id = call.get("id", "")
            try:
                arguments = json.loads(call["function"].get("arguments") or "{}")
            except json.JSONDecodeError:
                arguments = {}

            if name in READ_ONLY_TOOLS:
                try:
                    result = READ_ONLY_TOOLS[name](**arguments)
                except TypeError as exc:
                    result = f"Bad arguments for {name}: {exc}"
            elif name in GATED_TOOLS:
                description = _describe_gated_call(name, arguments)
                if request_approval(description):
                    try:
                        result = GATED_TOOLS[name](**arguments)
                    except TypeError as exc:
                        result = f"Bad arguments for {name}: {exc}"
                else:
                    result = "The user did not approve this action."
            else:
                result = f"Unknown tool: {name}"
            messages.append({"role": "tool", "tool_call_id": call_id, "content": result})

    return _("Sorry, I couldn't finish that after checking a few things.")


def _wrap_message_text(text, width=52):
    """Pre-wrap text with literal newlines at a fixed character width.

    Preserves intentional paragraph breaks (blank lines) from the model's
    own formatting -- only wraps within each paragraph, not across them.
    """
    paragraphs = text.split("\n\n")
    wrapped = [
        textwrap.fill(p, width=width) if p.strip() else p for p in paragraphs
    ]
    return "\n\n".join(wrapped)


class AssistantWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title=_("Pacific AI Assistant"))
        self.set_default_size(560, 640)
        self.set_position(Gtk.WindowPosition.CENTER)
        # No max-size geometry hint here (removed) -- it was a workaround
        # for window growth that turned out to be caused by a real bug
        # (see _on_reply/_wrap_message_text), not something that needed a
        # hard size cap. Keeping the hint after the real fix landed only
        # broke maximize/restore for no remaining benefit.

        self.server = LlamaServerManager()
        self.history = []
        self.connect("destroy", self.on_destroy)

        # Touch the Wnck screen singleton now, on the main thread, at
        # startup -- it populates its window list from passive X11 event
        # processing over time, not instantly. Without this warmup, the
        # very first list_open_windows tool call (which can happen soon
        # after the window opens) can race ahead of that and see an empty
        # list. Confirmed this race in real testing, not theoretical.
        Wnck.Screen.get_default()

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.add(outer)

        outer.pack_start(self._build_header(), False, False, 0)
        outer.pack_start(self._build_chat_area(), True, True, 0)
        outer.pack_start(self._build_input_area(), False, False, 0)

        self._start_server_async()

    def _build_header(self):
        outer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=14)
        outer.get_style_context().add_class("header-bar")
        outer.set_border_width(16)

        if os.path.exists(LOGO_PATH):
            pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(LOGO_PATH, 40, 40, True)
            outer.pack_start(Gtk.Image.new_from_pixbuf(pixbuf), False, False, 0)

        text_col = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)

        title = Gtk.Label(label=_("Pacific AI Assistant"), xalign=0)
        title.get_style_context().add_class("title")
        text_col.pack_start(title, False, False, 0)

        disclaimer = Gtk.Label(
            label=_(
                "Offline, best-effort. Answers and translations may be "
                "inaccurate -- use Disaster Readiness / Services Directory "
                "for official information."
            ),
            xalign=0,
            wrap=True,
        )
        disclaimer.get_style_context().add_class("disclaimer")
        text_col.pack_start(disclaimer, False, False, 0)

        outer.pack_start(text_col, True, True, 0)

        return outer

    def _build_chat_area(self):
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        self.chat_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        self.chat_box.set_border_width(18)
        scroller.add(self.chat_box)
        self.scroller = scroller

        self.status_label = Gtk.Label(label=_("Starting the assistant…"), xalign=0.5)
        self.status_label.get_style_context().add_class("status")
        self.chat_box.pack_start(self.status_label, False, False, 0)

        return scroller

    def _build_input_area(self):
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        row.set_border_width(14)

        self.entry = Gtk.Entry()
        self.entry.set_placeholder_text(_("Ask something…"))
        self.entry.set_sensitive(False)
        self.entry.connect("activate", self.on_send)
        row.pack_start(self.entry, True, True, 0)

        self.send_button = Gtk.Button(label=_("Send"))
        self.send_button.get_style_context().add_class("send-button")
        self.send_button.set_sensitive(False)
        self.send_button.connect("clicked", self.on_send)
        row.pack_start(self.send_button, False, False, 0)

        return row

    def _start_server_async(self):
        def worker():
            try:
                self.server.start()
                self.server.wait_ready()
            except AssistantStartupError as exc:
                GLib.idle_add(self._on_server_ready, str(exc))
                return
            except Exception as exc:  # noqa: BLE001 -- must never fail silently here
                GLib.idle_add(self._on_server_ready, str(exc))
                return
            GLib.idle_add(self._on_server_ready, None)

        threading.Thread(target=worker, daemon=True).start()

    def _on_server_ready(self, error):
        if error is None:
            self.status_label.set_text(_("Ready. Ask a question below."))
            self.entry.set_sensitive(True)
            self.send_button.set_sensitive(True)
            self.entry.grab_focus()
        else:
            self.status_label.set_text(_("Could not start the assistant: {error}").format(error=error))
        return False

    def _add_message(self, text, is_user, is_thinking=False):
        column = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        column.set_halign(Gtk.Align.END if is_user else Gtk.Align.START)

        # .upper() here since GTK's CSS engine doesn't support text-transform
        # (that's a web-CSS-only property) -- the uppercase styling has to
        # happen in Python instead.
        role_text = (_("You") if is_user else _("Assistant")).upper()
        role = Gtk.Label(label=role_text, xalign=1 if is_user else 0)
        role.get_style_context().add_class("role-label")
        role.get_style_context().add_class("role-user" if is_user else "role-assistant")
        column.pack_start(role, False, False, 0)

        # GtkLabel's own wrap/max-width-chars/size-request mechanisms were
        # each tried and each failed to reliably stop the window from
        # growing to fit long replies (confirmed against the real live
        # session, not just local guessing). Sidestepping the problem
        # entirely: pre-wrap the text ourselves with literal newlines before
        # it ever reaches the label, so there is no negotiation for GTK to
        # get wrong -- the label just displays lines that are already short.
        label = Gtk.Label(label=_wrap_message_text(text), xalign=0, wrap=True)
        label.set_selectable(True)
        label.set_line_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        if is_thinking:
            label.get_style_context().add_class("message-thinking")
        else:
            label.get_style_context().add_class("message-user" if is_user else "message-assistant")
        column.pack_start(label, False, False, 0)

        self.chat_box.pack_start(column, False, False, 0)
        column.show_all()
        return label

    def _scroll_to_bottom(self):
        adj = self.scroller.get_vadjustment()
        adj.set_value(adj.get_upper())
        return False

    def on_send(self, *_args):
        text = self.entry.get_text().strip()
        if not text:
            return
        self.entry.set_text("")
        self.entry.set_sensitive(False)
        self.send_button.set_sensitive(False)
        self._add_message(text, is_user=True)
        thinking_label = self._add_message(_("Thinking…"), is_user=False, is_thinking=True)
        GLib.idle_add(self._scroll_to_bottom)

        def worker():
            try:
                reply = query_assistant(text, self.history, self._request_approval)
            except Exception as exc:
                reply = _("Sorry, something went wrong: {error}").format(error=exc)
            GLib.idle_add(self._on_reply, text, reply, thinking_label)

        threading.Thread(target=worker, daemon=True).start()

    def _request_approval(self, action_description):
        """Called from the background worker thread. Blocks that thread
        (never the GTK main loop) until the user answers a real dialog --
        every gated action asks every time, no "always allow"."""
        result = {}
        done = threading.Event()

        def show_dialog():
            dialog = Gtk.MessageDialog(
                transient_for=self,
                modal=True,
                message_type=Gtk.MessageType.QUESTION,
                buttons=Gtk.ButtonsType.YES_NO,
                text=_("Allow this action?"),
            )
            dialog.format_secondary_text(
                _("The assistant wants to {action}.").format(action=action_description)
            )
            response = dialog.run()
            dialog.destroy()
            result["allowed"] = response == Gtk.ResponseType.YES
            done.set()
            return False

        GLib.idle_add(show_dialog)
        done.wait(timeout=120)
        return result.get("allowed", False)

    def _on_reply(self, user_text, reply, thinking_label):
        thinking_label.set_text(_wrap_message_text(reply))
        style = thinking_label.get_style_context()
        style.remove_class("message-thinking")
        style.add_class("message-assistant")
        self.history.append({"role": "user", "content": user_text})
        self.history.append({"role": "assistant", "content": reply})
        self.entry.set_sensitive(True)
        self.send_button.set_sensitive(True)
        self.entry.grab_focus()
        GLib.idle_add(self._scroll_to_bottom)
        return False

    def on_destroy(self, *_args):
        self.server.stop()
        Gtk.main_quit()


def main():
    provider = Gtk.CssProvider()
    provider.load_from_data(CSS)
    Gtk.StyleContext.add_provider_for_screen(
        Gdk.Screen.get_default(),
        provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
    )

    win = AssistantWindow()
    win.show_all()
    Gtk.main()


if __name__ == "__main__":
    main()
