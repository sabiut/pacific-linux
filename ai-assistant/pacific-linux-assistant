class AssistantStartupError(Exception):
    """Raised with a specific, user-facing reason -- the caller must never
    let a startup failure disappear silently (that was the earlier bug:
    the UI stayed on "Starting the assistant..." forever with no feedback
    if llama-server failed to launch for any reason)."""


class LlamaServerManager:
    """Starts/stops the llama-server subprocess on demand -- not resident
    from boot, so idle RAM stays free on constrained hardware."""

    def __init__(self):
        self.process = None

    def start(self):
        if self.process is not None:
            return
        if not os.path.exists(LLAMA_SERVER_BIN):
            raise AssistantStartupError(
                _("llama-server is missing ({path}).").format(path=LLAMA_SERVER_BIN)
            )
        if not os.path.exists(MODEL_PATH):
            raise AssistantStartupError(
                _("The assistant model is missing ({path}).").format(path=MODEL_PATH)
            )
        try:
            self.process = subprocess.Popen(
                [
                    LLAMA_SERVER_BIN,
                    "-m", MODEL_PATH,
                    "--port", str(SERVER_PORT),
                    "--host", "127.0.0.1",
                    "-c", "4096",
                ],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        except OSError as exc:
            raise AssistantStartupError(
                _("Could not launch llama-server: {error}").format(error=exc)
            )

    def wait_ready(self, timeout=90):
        deadline = time.time() + timeout
        while time.time() < deadline:
            if self.process.poll() is not None:
                raise AssistantStartupError(
                    _("llama-server exited unexpectedly (code {code}).").format(
                        code=self.process.returncode
                    )
                )
            try:
                urllib.request.urlopen(f"{SERVER_URL}/health", timeout=2)
                return
            except Exception:
                time.sleep(0.5)
        raise AssistantStartupError(_("Timed out waiting for the assistant to start."))

    def stop(self):
        if self.process is None:
            return
        self.process.terminate()
        try:
            self.process.wait(timeout=5)
        except subprocess.TimeoutExpired:
            self.process.kill()
        self.process = None


